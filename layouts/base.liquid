<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}{% if ogType == "article" %} · Dashiell Vallance{% endif %}</title>
  <meta name="author" content="Dashiell Vallance">
  {% if description %}
  <meta name="description" content="{{ description }}">
  <meta property="og:description" content="{{ description }}">
  <meta name="twitter:description" content="{{ description }}">
  {% endif %}
  <link rel="canonical" href="https://dashdot.me{{ page.url }}">
  <meta property="og:site_name" content="Dashiell Vallance">
  <meta property="og:locale" content="en_US">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:url" content="https://dashdot.me{{ page.url }}">
  <meta property="og:type" content="{{ ogType | default: 'website' }}">
  {% if ogType == "article" %}
  <meta property="article:published_time" content="{{ page.date | date: '%Y-%m-%dT%H:%M:%SZ' }}">
  <meta property="article:author" content="Dashiell Vallance">
  {% endif %}
  {% if ogImage %}
  <meta property="og:image" content="https://dashdot.me{{ ogImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:image" content="https://dashdot.me{{ ogImage }}">
  <meta name="twitter:card" content="summary_large_image">
  {% else %}
  <meta name="twitter:card" content="summary">
  {% endif %}
  <meta name="twitter:title" content="{{ title }}">
  {% if draft %}<meta name="robots" content="noindex, nofollow">{% endif %}
  <link rel="alternate" type="application/atom+xml" title="RSS Feed" href="/feed.atom">
  <link rel="alternate" type="application/atom+xml" title="RSS Feed — Technical" href="/feed/technical.atom">
  <link rel="alternate" type="application/atom+xml" title="RSS Feed — Personal" href="/feed/personal.atom">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito+Sans:wght@400;600;700;800;900&display=swap">
  <link rel="stylesheet" href="/style.css">
  {% if ogType == "article" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ title | jsonString }},
    {% if description %}"description": {{ description | jsonString }},{% endif %}
    "datePublished": "{{ page.date | date: '%Y-%m-%d' }}",
    "dateModified": "{{ page.date | date: '%Y-%m-%d' }}",
    "author": { "@type": "Person", "name": "Dashiell Vallance", "url": "https://dashdot.me/" },
    "publisher": { "@type": "Person", "name": "Dashiell Vallance", "url": "https://dashdot.me/" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://dashdot.me{{ page.url }}" },
    "url": "https://dashdot.me{{ page.url }}"{% if ogImage %},
    "image": "https://dashdot.me{{ ogImage }}"{% endif %}
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Dashiell Vallance",
    "url": "https://dashdot.me/",
    {% if description %}"description": {{ description | jsonString }},{% endif %}
    "author": {
      "@type": "Person",
      "name": "Dashiell Vallance",
      "url": "https://dashdot.me/",
      "sameAs": [
        "https://github.com/dashdotme",
        "https://www.linkedin.com/in/dashvallance/"
      ]
    }
  }
  </script>
  {% endif %}
</head>
<body>
  {{ content }}
  <script src="/base.js"></script>
 </body>
</html>
